# URL of your running Fleet Command dashboard
# If running on this same PC use localhost. If remote, use the LAN IP.
FLEET_API_URL=http://localhost:3002

# The fleet node's UUID from the Supabase fleets table
FLEET_ID=paste-your-fleet-node-uuid-here

# The access_key stored in fleets.credentials for this node
HOST_ACCESS_KEY=paste-your-access-key-here

# Screen capture settings
CAPTURE_FPS=15
MONITOR_INDEX=1
